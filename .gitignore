# ==========================================
# 仮想環境 (Virtual Environments)
# 各自のPC環境依存であり、容量が膨大になるため除外
# ==========================================
.venv/
venv/
ENV/
env/

# ==========================================
# プロジェクト固有の自動生成ファイル
# 実行するたびに生成されるスクショやログを除外
# ==========================================
screenshots/
*.log

# ==========================================
# Pythonコンパイルキャッシュ (Python Bytecode)
# 実行速度向上のために自動生成される内部ファイル（競合の原因）
# ==========================================
__pycache__/
*.pyc
*.pyo
*.pyd

# ==========================================
# エディタ・OS固有の設定ファイル (隠しファイル)
# 開発者個人の画面設定などが含まれるため除外
# ==========================================
.vscode/
.idea/
.DS_Store
Thumbs.db